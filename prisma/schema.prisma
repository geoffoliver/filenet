generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Identity {
  id         String   @id @default(cuid())
  nodeId     String   @unique
  publicKey  String
  privateKey String
  createdAt  DateTime @default(now())
}

model Friend {
  id         String       @id @default(cuid())
  name       String
  nodeId     String?      @unique
  address    String
  port       Int          @default(7734)
  publicKey  String?
  status     FriendStatus @default(OUTGOING_PENDING)
  addedAt    DateTime     @default(now())
  acceptedAt DateTime?
  updatedAt  DateTime     @updatedAt

  @@unique([address, port])
}

enum FriendStatus {
  OUTGOING_PENDING
  INCOMING_PENDING
  ACCEPTED
  BLOCKED
}

model Settings {
  id                          String  @id @default("singleton")
  name                        String  @default("")
  invitePassword              String?
  autoAcceptFromAnyone        Boolean @default(false)
  autoAcceptFromFriendsOfFriends Boolean @default(false)
}
