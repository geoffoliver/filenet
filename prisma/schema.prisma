generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Identity {
  id         String   @id @default(cuid())
  nodeId     String   @unique
  publicKey  String
  privateKey String
  createdAt  DateTime @default(now())
}

model Friend {
  id         String       @id @default(cuid())
  name       String
  nodeId     String?      @unique
  address    String
  port       Int          @default(7734)
  publicKey  String?
  status     FriendStatus @default(OUTGOING_PENDING)
  addedAt    DateTime     @default(now())
  acceptedAt DateTime?
  updatedAt  DateTime     @updatedAt

  @@unique([address, port])
}

enum FriendStatus {
  OUTGOING_PENDING
  INCOMING_PENDING
  ACCEPTED
  BLOCKED
}

model Settings {
  id                             String  @id @default("singleton")
  name                           String  @default("")
  invitePassword                 String?
  autoAcceptFromAnyone           Boolean @default(false)
  autoAcceptFromFriendsOfFriends Boolean @default(false)
  sharedFolders                  String  @default("[]")
  downloadFolder                 String?
  rescanIntervalMinutes          Int     @default(0)
  listenPort                     Int     @default(7734)
}

enum DownloadState {
  PENDING
  DOWNLOADING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

model Download {
  id              String        @id @default(cuid())
  sha256          String
  filename        String
  size            BigInt
  mimeType        String?
  state           DownloadState @default(PENDING)
  bytesReceived   BigInt        @default(0)
  chunkSize       Int           @default(1048576)
  completedChunks String        @default("[]") // JSON: number[] of completed chunk indices
  sources         String        @default("[]") // JSON: string[] of nodeIds
  tmpPath         String?
  downloadFolder  String?
  finalPath       String?
  error           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  completedAt     DateTime?
}

enum ConvType {
  DM
  GROUP
}

model Conversation {
  id        String    @id // dm:{nodeA}:{nodeB} (sorted) or group:{uuid}
  type      ConvType  @default(DM)
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fromNodeId     String
  body           String
  sentAt         DateTime

  @@index([conversationId, sentAt])
}

model SharedFile {
  id             String    @id @default(cuid())
  path           String    @unique
  filename       String
  size           BigInt
  sha256         String
  mimeType       String?
  metadata       String?
  fileModifiedAt DateTime?
  lastSeenAt     DateTime  @default(now())
  indexedAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model PostDownloadScript {
  id        String   @id @default(cuid())
  path      String   @unique
  order     Int
  createdAt DateTime @default(now())
}
